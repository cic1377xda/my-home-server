# ==============================================================================
# MEDIA SERVER - ENVIRONMENT VARIABLES
# Rename this file to .env and adjust the paths to match your server setup.
# ==============================================================================

# User and Group IDs (Run 'id' in terminal to find yours)
PUID=1000
PGID=1000

# Timezone
TZ=Asia/Kuala_Lumpur

# ------------------------------------------------------------------------------
# DIRECTORY PATHS
# ------------------------------------------------------------------------------
# Point this to where you want the app settings and databases to be stored
CONFIG_DIR=/mnt/media_stack/config

# Point this to your main storage drive. 
# CRITICAL: Both torrents and media MUST be under the same root directory 
# for hardlinks (atomic moves) to work properly and save disk space.
DATA_DIR=/mnt/data
