# ==============================================================================
# NEXTCLOUD & ONLYOFFICE - ENVIRONMENT VARIABLES (EXAMPLE)
# Rename this to .env and change all passwords before running docker compose!
# ==============================================================================

# --- SYSTEM CONFIGURATION ---
TZ=Asia/Kuala_Lumpur

# --- DIRECTORY PATHS ---
# Define the root path where persistent data will be stored
NEXTCLOUD_ROOT_DIR=/path/to/your/storage/nextcloud_stack

# --- NETWORK CONFIGURATION ---
# The domain name you will use to access Nextcloud
NEXTCLOUD_DOMAIN=nextcloud.yourdomain.com
# Port mappings for host access
NEXTCLOUD_PORT=8080
ONLYOFFICE_PORT=8084

# --- MARIADB CREDENTIALS ---
MYSQL_ROOT_PASSWORD=your_super_strong_root_password
MYSQL_DATABASE=nextcloud
MYSQL_USER=ncuser
MYSQL_PASSWORD=your_super_strong_nc_password

# --- ONLYOFFICE SECURITY ---
# A strong random string required for secure communication with Nextcloud
ONLYOFFICE_JWT_SECRET=your_super_strong_jwt_secret_here
