# ==============================================================================
# IMMICH - ENVIRONMENT VARIABLES (EXAMPLE)
# Rename this to .env and change the database password before deploying.
# ==============================================================================

# --- SYSTEM CONFIGURATION ---
TZ=Asia/Kuala_Lumpur
IMMICH_VERSION=v2

# --- DIRECTORY PATHS ---
# Main storage location for high-res photos and videos
UPLOAD_LOCATION=/path/to/your/storage/immich_data
# Local database storage path (Must be SSD/NVMe for best performance)
DB_DATA_LOCATION=./postgres

# --- DATABASE CREDENTIALS ---
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
# IMPORTANT: Use a strong, random alphanumeric string without spaces
DB_PASSWORD=your_secure_database_password_here

# ==============================================================================
# MACHINE LEARNING & HARDWARE OPTIMIZATION (LOW-RESOURCE MODE)
# ==============================================================================

# 1. Thread Control: Limit ML tasks to prevent 100% CPU bottlenecking
MACHINE_LEARNING_WORKERS=1

# 2. Model Selection: Use lightweight, high-speed models to conserve RAM
MACHINE_LEARNING_CLIP_MODEL_NAME=Xenova/all-MiniLM-L6-v2
MACHINE_LEARNING_FACIAL_RECOGNITION_MODEL_NAME=buffalo_s

# 3. Memory Management: Unload ML models from RAM after 300 seconds of inactivity
MACHINE_LEARNING_MODEL_TTL=300

# 4. FFmpeg Concurrency: Limit video thumbnail generation threads to avoid crashes
IMMICH_MACHINE_LEARNING_worker_concurrency=1
