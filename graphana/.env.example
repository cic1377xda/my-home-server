# ==============================================================================
# SERVER MONITORING STACK - ENVIRONMENT VARIABLES (EXAMPLE)
# Rename this to .env and replace the dummy values with your actual secure keys.
# ==============================================================================

# --- SYSTEM CONFIGURATION ---
TZ=Asia/Kuala_Lumpur

# --- DIRECTORY PATHS ---
# Define the root path where persistent monitoring data will be stored
DATA_DIR=/path/to/your/storage/monitoring_data

# --- GRAFANA CREDENTIALS ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_secure_grafana_password

# --- MARIADB CREDENTIALS (OPTIONAL FOR IoT EXTENSION) ---
# Used if you are extending this stack to store custom IoT telemetry
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_USER=iot_admin
MYSQL_PASSWORD=your_secure_iot_password
