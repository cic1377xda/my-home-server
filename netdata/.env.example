# ==============================================================================
# NETDATA - ENVIRONMENT VARIABLES
# Rename this file to .env and adjust the values accordingly.
# ==============================================================================

# Timezone for accurate metric logging
TZ=Asia/Kuala_Lumpur

# Server Hostname (This name will appear on your Netdata Dashboard)
HOSTNAME=pwn20wndserver

# Port Configuration
NETDATA_PORT=19999

# (OPTIONAL) Netdata Cloud Integration
# Get your claim token from https://app.netdata.cloud/ if you want cloud access
NETDATA_CLAIM_TOKEN=your_netdata_cloud_claim_token_here
NETDATA_CLAIM_ROOMS=your_netdata_cloud_room_id_here
