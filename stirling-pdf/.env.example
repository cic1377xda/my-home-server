# ==============================================================================
# STIRLING-PDF - ENVIRONMENT VARIABLES (EXAMPLE)
# Rename to .env and adjust the values. DO NOT commit .env to GitHub.
# ==============================================================================

# Timezone Configuration
TZ=Asia/Kuala_Lumpur

# Host Port Configuration
STIRLING_PDF_PORT=8087

# --- SECURITY & FEATURE TOGGLES ---
# Set to 'true' to enable login/authentication system
DOCKER_ENABLE_SECURITY=false

# Advanced Features
INSTALL_BOOK_AND_ADVANCED_HTML_OPS=false
LANGS=eng
SYSTEM_DEFAULTLOCALE=en_US
