# ==============================================================================
# n8n AUTOMATION - ENVIRONMENT VARIABLES (EXAMPLE)
# Rename this to .env and change all credentials before deploying!
# ==============================================================================

# --- SYSTEM CONFIGURATION ---
TZ=Asia/Kuala_Lumpur

# --- DIRECTORY PATHS ---
# Define where persistent n8n data (workflows, credentials, execution history) is stored
N8N_DATA_DIR=/path/to/your/storage/n8n_data

# --- NETWORK & WEBHOOK CONFIGURATION ---
N8N_PORT=5678
# The public URL of your n8n instance (critical for receiving external webhooks)
N8N_WEBHOOK_URL=https://n8n.yourdomain.com

# --- SECURITY (BASIC AUTH) ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_super_strong_password_here
