# ==============================================================================
# OPEN WEBUI - ENVIRONMENT VARIABLES (EXAMPLE)
# Rename this to .env and fill in your actual keys. DO NOT commit .env to GitHub!
# ==============================================================================

# --- SYSTEM CONFIGURATION ---
TZ=Asia/Kuala_Lumpur
WEBUI_PORT=3030

# --- DIRECTORY PATHS ---
# Define where Open WebUI should store chat history and user data
OPEN_WEBUI_DIR=/path/to/your/data/open-webui_data

# --- SECURITY & API KEYS ---
# Secret key for JWT token generation (Ensure this is a strong random string)
WEBUI_SECRET_KEY=your_random_secret_key_here

# OpenRouter API Key for LLM backend access
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
