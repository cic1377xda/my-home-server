# ==============================================================================
# CLOUDFLARE DDNS - ENVIRONMENT VARIABLES (EXAMPLE)
# Rename this to .env and replace with your actual API token.
# DO NOT commit the .env file to version control!
# ==============================================================================

# System Timezone
TZ=Asia/Kuala_Lumpur

# --- CLOUDFLARE CREDENTIALS ---
# Your Cloudflare API Token (Requires Zone:DNS:Edit permissions)
CF_API_KEY=your_cloudflare_api_token_here

# The root domain managed in Cloudflare
CF_ZONE=example.com

# --- SUBDOMAINS ---
# Subdomain 1 (e.g., for Web UI, usually Proxied)
CF_SUBDOMAIN_1=dns
# Subdomain 2 (e.g., for DNS-over-TLS, must be DNS-Only/Grey Cloud)
CF_SUBDOMAIN_2=dot
