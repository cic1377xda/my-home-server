# ==========================================
# ADGUARD HOME - ENVIRONMENT VARIABLES
# ==========================================
# Rename this file to .env and fill in your actual values.
# DO NOT commit the actual .env file to version control.

# Set your timezone
TZ=Asia/Kuala_Lumpur

# Network Configuration (Optional: If using specific external networks)
NETWORK_NAME=pwn20wnd-network

# Provide your Cloudflare API Token for SSL Renewal (Used in renew-cert.sh)
CF_API_TOKEN=your_cloudflare_token_here
