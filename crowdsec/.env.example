# ==============================================================================
# CROWDSEC HYBRID AGENT - ENVIRONMENT VARIABLES
# Rename this to .env and adjust the paths to match your server setup.
# ==============================================================================

# Timezone Configuration
TZ=Asia/Kuala_Lumpur

# System Group ID (Run 'id' on your host terminal to find your GID)
GID=1000

# --- CRITICAL PATH MAPPINGS ---
# Ensure these paths correctly point to your Reverse Proxy logs.
# The CrowdSec agent needs READ-ONLY access to analyze incoming traffic.
NPM_LOGS_DIR=/path/to/your/npm/data/logs

# --- PORT CONFIGURATION ---
# The Local API (LAPI) port. The Host Firewall Bouncer connects to this port.
CROWDSEC_LAPI_PORT=8082
